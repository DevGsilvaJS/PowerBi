# Copie para variáveis de ambiente no Render, Docker ou Azure (não commite segredos reais).
# No Windows PowerShell: $env:ConnectionStrings__DefaultConnection = "..."
# Linux / Render: defina no painel ou docker run -e

# Obrigatório em produção — PostgreSQL (Npgsql)
# Exemplo Render (PostgreSQL gerenciado): use o Internal Database URL ou monte manualmente:
#   Host=...;Port=5432;Database=powerbi;Username=...;Password=...;SSL Mode=Require
ConnectionStrings__DefaultConnection=

# Obrigatório em produção — chave JWT (mínimo 32 caracteres)
Jwt__Key=

# Ambiente (Render: Production)
ASPNETCORE_ENVIRONMENT=Production

# Opcional — Render injeta PORT; o Program.cs já lê. Para Docker local fixo:
# ASPNETCORE_URLS=http://0.0.0.0:8080
# PORT=8080
